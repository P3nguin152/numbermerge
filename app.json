{
  "expo": {
    "name": "NumberMerger",
    "slug": "numbermerger",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.numbermerge.game"
    },
    "android": {
      "package": "com.numbermerge.game",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "splash": {
        "image": "./assets/splash.png",
        "backgroundColor": "#0A0E21",
        "resizeMode": "contain"
      },
      "permissions": []
    },
    "web": {
      "bundler": "webpack"
    },
    "extra": {
      "eas": {
        "projectId": "your-project-id-here"
      }
    },
    "privacy": "https://your-privacy-policy-url.com"
  }
}
